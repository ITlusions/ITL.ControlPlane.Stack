# ITL ControlPlane Stack Environment Variables
# Copy this file to .env and fill in the values
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your values
#   # Run setup script to populate Keycloak secrets:
#   cd ../ITL.ControlPlane.ResourceProvider.Identity/config
#   .\setup-keycloak-client.ps1 -AdminUsername admin -AdminPassword <your-password>

# ══════════════════════════════════════════════════════════════
# Keycloak Admin Credentials
# ══════════════════════════════════════════════════════════════
# Used by docker-compose to configure Keycloak container
# Change these before first deployment in production!
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_BEFORE_PRODUCTION

# ══════════════════════════════════════════════════════════════
# Keycloak Service Account (populated by setup script)
# ══════════════════════════════════════════════════════════════
# Run setup-keycloak-client.ps1 to generate and populate this value
KEYCLOAK_CLIENT_SECRET=RUN_SETUP_SCRIPT_TO_GENERATE

# ══════════════════════════════════════════════════════════════
# Docker Socket (auto-detected)
# ══════════════════════════════════════════════════════════════
# Windows: DOCKER_SOCKET=//var/run/docker.sock
# Linux:   DOCKER_SOCKET=/var/run/docker.sock
# DOCKER_SOCKET=/var/run/docker.sock
